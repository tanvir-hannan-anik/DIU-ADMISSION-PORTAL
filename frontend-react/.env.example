# Backend service URLs
REACT_APP_API_URL=http://localhost:8080/api
REACT_APP_AI_URL=http://localhost:5000
REACT_APP_DEBUG=false
REACT_APP_TIMEOUT=30000

# ── Firebase (Google Workspace auth + Firestore student data) ─────────────
# Firebase console → Project settings → General → Your apps → "SDK setup
# and configuration" → Config. Copy each value from the firebaseConfig object.
REACT_APP_FIREBASE_API_KEY=your_firebase_web_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=diu-admission-portal.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=diu-admission-portal
REACT_APP_FIREBASE_STORAGE_BUCKET=diu-admission-portal.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id
