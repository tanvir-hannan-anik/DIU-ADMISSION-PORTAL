# ── Groq LLM (chat / advisor / proctor / vision) ──────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY_2=
GROQ_MODEL_2=llama-3.3-70b-versatile
GROQ_API_KEY_3=
GROQ_MODEL_3=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
RAPIDAPI_KEY=

# ── RAG: Google Gemini embeddings (free tier, multilingual, Render-safe) ───
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_EMBED_MODEL=gemini-embedding-001
EMBED_DIM=768

# ── RAG: Qdrant Cloud vector store ────────────────────────────────────────
# Create a free cluster at https://cloud.qdrant.io
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=diu_kb

# RAG tuning. RAG_ENABLED=false makes the bot use the legacy static prompt.
RAG_ENABLED=true
RAG_TOP_K=6
RAG_MIN_SCORE=0.30

# ── Server ────────────────────────────────────────────────────────────────
FLASK_ENV=development
SERVICE_HOST=0.0.0.0
SERVICE_PORT=5000
LOG_LEVEL=INFO
MAX_TOKENS=1024
